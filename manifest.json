{
  "manifest_version": 3,
  "name": "Netflix PiP Unblocker",
  "version": "1.0.0",
  "description": "Re-enables Picture-in-Picture on Netflix when it is blocked. The toolbar icon turns orange; click it to turn PiP back on.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/default-16.png",
    "32": "icons/default-32.png",
    "48": "icons/default-48.png",
    "128": "icons/default-128.png"
  },
  "action": {
    "default_title": "Netflix PiP Unblocker",
    "default_icon": {
      "16": "icons/default-16.png",
      "32": "icons/default-32.png",
      "48": "icons/default-48.png",
      "128": "icons/default-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/lib/pip-core.js"],
      "matches": ["*://*.netflix.com/*"]
    }
  ]
}
